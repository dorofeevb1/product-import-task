APP_ENV=dev
APP_DEBUG=1
DB_DRIVER=pdo_pgsql
DB_HOST=db
DB_PORT=5432
DB_NAME=products
DB_USER=app
DB_PASSWORD=app
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f
IMPORT_QUEUE_NAME=import_products
MAX_UPLOAD_SIZE_MB=10
MAX_IMAGE_SIZE_MB=5
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=3
IMAGE_CONNECT_TIMEOUT_SECONDS=1.5
MAX_IMAGES_PER_PRODUCT=2
IMPORT_SKIP_IMAGES=0
IMPORT_STORE_SOURCE_URL_ONLY=0
FAST_IMPORT_MODE=0
FAST_IMPORT_BATCH_SIZE=5000
APP_SECRET=change-me
JWT_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=1209600
JWT_ISSUER=product-import-api
JWT_AUDIENCE=product-import-frontend
